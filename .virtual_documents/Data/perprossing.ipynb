def create_dataset_versions(df):

    # ================= V1 =================
    v1 = df.copy()

    cat_cols = v1.select_dtypes(include="object").columns

    for col in cat_cols:
        le = LabelEncoder()
        v1[col] = le.fit_transform(v1[col].astype(str))

    # ================= V2 =================
    v2 = df.copy()

    v2["Model"] = v2["Model"].map(v2["Model"].value_counts())
    v2["Location"] = v2["Location"].map(v2["Location"].value_counts())

    v2 = pd.get_dummies(
        v2,
        columns=[
            "Brand",
            "Fuel_Type",
            "Transmission",
            "Owner_Type"
        ],
        drop_first=True
    )

    # ================= V3 =================
    v3 = df.copy()

    v3["Model"] = v3["Model"].map(v3["Model"].value_counts())

    v3 = pd.get_dummies(
        v3,
        columns=[
            "Brand",
            "Location",
            "Fuel_Type",
            "Transmission",
            "Owner_Type"
        ],
        drop_first=True
    )

    return v1, v2, v3


